generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Parent {
  id          String   @id @default(cuid())
  israeliId   String   @unique @map("israeli_id")
  displayName String   @map("display_name")
  createdAt   DateTime @default(now()) @map("created_at")

  childrenAsParent1 Child[] @relation("Parent1")
  childrenAsParent2 Child[] @relation("Parent2")

  @@map("parents")
}

model Child {
  id        String   @id @default(cuid())
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  grade     String   @default("")
  israeliId String?  @unique @map("israeli_id_child")
  createdAt DateTime @default(now()) @map("created_at")

  parent1Id String  @map("parent1_id")
  parent1   Parent  @relation("Parent1", fields: [parent1Id], references: [id])

  parent2Id String? @map("parent2_id")
  parent2   Parent? @relation("Parent2", fields: [parent2Id], references: [id])

  completions TaskCompletion[]
  answers     QuestionAnswer[]

  @@map("children")
}

model Task {
  id        String   @id @default(cuid())
  name      String
  icon      String   @default("Star")
  color     String   @default("#3B82F6")
  points    Int      @default(1)
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  completions TaskCompletion[]

  @@map("tasks")
}

model TaskCompletion {
  id          String   @id @default(cuid())
  childId     String   @map("child_id")
  taskId      String   @map("task_id")
  date        DateTime @db.Date
  completedAt DateTime @default(now()) @map("completed_at")

  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)
  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([childId, taskId, date])
  @@map("task_completions")
}

model Campaign {
  id             String @id @default("singleton")
  startDate      DateTime @db.Date @map("start_date")
  activeWeekdays Int[]  @map("active_weekdays")
  maxBackDays    Int    @default(1) @map("max_back_days")

  @@map("campaign")
}

model FlashMessage {
  id        String   @id @default(cuid())
  content   String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("flash_messages")
}

model Question {
  id                 String   @id @default(cuid())
  text               String
  grade              String
  options            String[]
  correctAnswerIndex Int      @map("correct_answer_index")
  isArchived         Boolean  @default(false) @map("is_archived")
  createdAt          DateTime @default(now()) @map("created_at")

  answers QuestionAnswer[]

  @@map("questions")
}

model QuestionAnswer {
  id                  String   @id @default(cuid())
  childId             String   @map("child_id")
  questionId          String   @map("question_id")
  selectedAnswerIndex Int      @map("selected_answer_index")
  isCorrect           Boolean  @map("is_correct")
  answeredAt          DateTime @default(now()) @map("answered_at")

  child    Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([childId, questionId])
  @@map("question_answers")
}
